   8++69C4              ; "!"  - логическое отрицание a=0 -> a=1; a<>0 -> a=0
   9++69C4              ; "^"  - побитное инвертирование
  10++69C4              ; "-"  - унарный минус
  11++69C4              ; "+"  - унарный плюс
  12++69C4              ; "++" - инкремент a=a+1
  13++69C4              ; "--" - декремент a=a-1
  14++69C4              ; "<"  - младший байт числа
  15++69C4              ; ">"  - старший байт числа
  16++69C4              ; "?"  - метка определена -> 1 ; не определена -> 0
  17++69C4              ;  двуместные операции
  18++69C4              ; "<<" - циклический сдвиг влево
  19++69C4              ; ">>" - циклический сдвиг вправо
  20++69C4              ;
  21++69C4              ; "*"  - умножение
  22++69C4              ; "/"  - деление
  23++69C4              ; "\"  - остаток от деления
  24++69C4              ;
  25++69C4              ; "+"  - сложение
  26++69C4              ; "-"  - вычитание
  27++69C4              ;
  28++69C4              ; "<"  - меньше
  29++69C4              ; "="  - равно
  30++69C4              ; ">"  - больше
  31++69C4              ; "<=" - меньше или равно
  32++69C4              ; "<>" - не равно
  33++69C4              ; ">=" - больше или равно
  34++69C4              ;
  35++69C4              ; "!"  - побитный XOR
  36++69C4              ; "&"  - побитный AND
