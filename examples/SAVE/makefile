ASM = ..\..\ORGASM.EXE
SRC = MAIN.ASM
OUT1 = OUT\CODE.BIN
OUT2 = OUT\COPY.BIN
OUT3 = OUT\HIGH.BIN
DELTOOL = MKDEL.EXE

.PHONY: all clean

all: $(OUT1) $(OUT2) $(OUT3)

$(OUT1): $(SRC)
	$(ASM) $(SRC) /N /L=SAVE.ERR

$(OUT2): $(SRC)
	$(ASM) $(SRC) /N /L=SAVE.ERR

$(OUT3): $(SRC)
	$(ASM) $(SRC) /N /L=SAVE.ERR

clean:
	-$(DELTOOL) $(OUT1)
	-$(DELTOOL) $(OUT2)
	-$(DELTOOL) $(OUT3)
	-$(DELTOOL) SAVE.ERR
