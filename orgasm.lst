  26:	605A  3F      			ccf
  27:	605B  D0      			ret nc
  28:	605C  FE3A    			cp ":"
  29:	605E  C9      			ret
  30:			;
  31:			;-- Перевод символа в CapsLock --
  32:			;Символ из A переводится в верхний регистр (только латинские буквы)
  33:			;
  34:	605F  FE61    	CapsLetter	cp #61		;<"a"
  35:	6061  D8      			ret c
