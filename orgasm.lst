**** orgasm.asm ****
1292:			                include "calc.asm"
**** calc.asm ****
   1:			;-----------------------------------------------------------------------------
   2:			;--                              Калькулятор                                --
   3:			;--                    Расчет 16-ти битных выражений                        --
   4:			;--      с использованием метода трансляции в обратную польскую запись      --
   5:			;-----------------------------------------------------------------------------
   6:			;Поддерживаются следующие операции (от высшего приоритета к низшему):
   7:			;  одноместные операции (наивысший приоритет):
   8:			; "!"  - логическое отрицание a=0 -> a=1; a<>0 -> a=0
   9:			; "^"  - побитное инвертирование
  10:			; "-"  - унарный минус
  11:			; "+"  - унарный плюс
  12:			; "++" - инкремент a=a+1
  13:			; "--" - декремент a=a-1
  14:			; "<"  - младший байт числа
  15:			; ">"  - старший байт числа
  16:			; "?"  - метка определена -> 1 ; не определена -> 0
  17:			;  двуместные операции
  18:			; "<<" - циклический сдвиг влево
  19:			; ">>" - циклический сдвиг вправо
  20:			;
  21:			; "*"  - умножение
  22:			; "/"  - деление
  23:			; "\"  - остаток от деления
  24:			;
  25:			; "+"  - сложение
  26:			; "-"  - вычитание
  27:			;
  28:			; "<"  - меньше
  29:			; "="  - равно
  30:			; ">"  - больше
  31:			; "<=" - меньше или равно
  32:			; "<>" - не равно
  33:			; ">=" - больше или равно
  34:			;
  35:			; "!"  - побитный XOR
  36:			; "&"  - побитный AND
  37:			; "|"  - побитный OR
  38:			;
  39:			;Для изменения порядка расчета выражения используются скобки ()
  40:			;
  41:			;Вход  A  - первый символ выражения
  42:			;      HL - адрес следующего символа выражения
  43:			;Выход DE - значение выражения
  44:			;      A  - символ, на котором закончилось выражение
  45:			;      HL - адрес следующего символа строки
  46:			;
  47:	5B51  C5      	GetVar          push bc
  48:	5B52  47      	                ld b,a
  49:	5B53  3A6A69  	                ld a,(Pass)     ;номер прохода компилятора
  50:	5B56  3C      	                inc a
  51:	5B57  2839    	                jr z,GV2        ;на 2-ом проходе производим расчет выражений,
  52:	5B59  0E00    	                ld c,0
  53:	5B5B  78      	                ld a,b          ;иначе пропускаем выражение
  54:	5B5C  FE27    	GV3             cp #27          ;'   ;'
  55:	5B5E  2822    	                jr z,GV5
  56:	5B60  FE22    	                cp #22          ;"   ;"
  57:	5B62  281E    	                jr z,GV5
  58:	5B64  FE2C    	                cp ","
  59:	5B66  2810    	                jr z,GV6
  60:	5B68  FE3A    	                cp ":"
  61:	5B6A  280C    	                jr z,GV6
  62:	5B6C  FE3B    	                cp ";"
  63:	5B6E  2808    	                jr z,GV6
  64:	5B70  FE0D    	                cp #0d
  65:	5B72  2808    	                jr z,GV4
  66:	5B74  7E      	GV7             ld a,(hl)       ;следующий символ
  67:	5B75  23      	                inc hl
  68:	5B76  18E4    	                jr GV3
  69:			
  70:	5B78  0C      	GV6             inc c
  71:	5B79  0D      	                dec c
  72:	5B7A  20F8    	                jr nz,GV7
  73:	5B7C  ED5B9F69	GV4             ld de,(PCAddres);текущий программный адрес
  74:			;                ld e,0
  75:	5B80  C1      	                pop bc
  76:	5B81  C9      	                ret
  77:			
  78:	5B82  0C      	GV5             inc c
  79:	5B83  0D      	                dec c
  80:	5B84  2003    	                jr nz,GV8
  81:	5B86  4F      	                ld c,a
  82:	5B87  18EB    	                jr GV7
  83:	5B89  B9      	GV8             cp c
  84:	5B8A  20E8    	                jr nz,GV7
  85:	5B8C  0E00    	                ld c,0
  86:	5B8E  18E4    	                jr GV7
  87:			;
  88:			;Принудительный вызов калькулятора на первом проходе
  89:			;
  90:	5B90  C5      	GetVar2         push bc
  91:	5B91  47      	                ld b,a
  92:			;
  93:			;Собственно сам калькулятор
  94:			;
  95:	5B92  AF      	GV2             xor a
  96:	5B93  329069  	                ld (SPOp),a     ;инициализация стеков операций
  97:	5B96  329169  	                ld (SPNum),a    ;и переменных
  98:	5B99  78      	                ld a,b
  99:			
 100:	5B9A  119A5B  	GV1             ld de,GV1       ;адрес возврата после вычислений
 101:	5B9D  D5      	                push de         ;на стек
 102:	5B9E  FE20    	                cp " "          ;закончили на пробеле?
 103:	5BA0  CC6860  	                call z,SkipSpace
 104:	5BA3  FE09    	                cp #09          ;.. табуляции?
 105:	5BA5  CC6860  	                call z,SkipSpace
 106:	5BA8  0601    	                ld b,1          ;приоритет (
 107:	5BAA  FE28    	                cp "("          ;открывающаяся скобка
 108:	5BAC  CAD75D  	                jp z,PushOp     ;в стек операций
 109:	5BAF  D1      	                pop de          ;восстанавливаем вершину стека
 110:			
 111:	5BB0  FE3F    	                cp "?"          ;операция определения наличия метки в таблице
 112:	5BB2  CAFE5B  	                jp z,WheLabel
 113:	5BB5  FE5F    	                cp "_"          ;поиск метки
 114:	5BB7  CAEE5B  	                jp z,SearchLab
 115:	5BBA  FE2E    	                cp "."          ;поиск метки (заменено на точку в v0.2X)
