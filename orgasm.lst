 139:			
 140:	57B6  2B      	OD4		dec hl
 141:			;
 142:			;Определение выражения
 143:			;Вход: E - первый символ выражения
 144:			;      HL - адрес следующего символа
 145:			;
 146:	57B7  7B      	ODVar		ld a,e
 147:	57B8  06FE    			ld b,#fe	;код выражения в скобках
 148:	57BA  FE28    			cp "("
 149:	57BC  2821    			jr z,ODV1
 150:	57BE  04      			inc b		;код выражения
 151:			
 152:	57BF  CD4A60  	ODV4		call Letter	;попытка определить забытую пару AF'
 153:	57C2  301B    			jr nc,ODV1
 154:	57C4  E6DF    			and #df
 155:	57C6  FE41    			cp "A"		;пара AF?
 156:	57C8  7B      			ld a,e
 157:	57C9  2014    			jr nz,ODV1
 158:	57CB  7E      			ld a,(hl)
