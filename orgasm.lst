  71:	6083  FE0A    			cp #0a
  72:	6085  C0      			ret nz
  73:	6086  23      			inc hl
  74:			;		 ld a,b
  75:			;		 scf		 ;установить флаг "C"
  76:	6087  C9      			ret
  77:			;
