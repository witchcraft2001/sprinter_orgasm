**** d_label.asm ****
   1:			;-----------------------------------------------------------------------------
   2:			;--			  Процедуры обработки меток			    --
   3:			;-----------------------------------------------------------------------------
   4:			;  Таблица меток построена следующим образом:
   5:			; - метки расположены по возрастанию символов
   6:			; - каждая метка в таблице занимает от 4 до 255 байт
   7:			;    1 байт	- длина записи в таблице
   8:			;    1-252 байт - имя метки
   9:			;    2 байта	- значение метки
  10:			; - байт #00 является признаком конца таблицы
  11:			;
  12:			;-- Сканирование метки --
  13:			;конец метки определяется:
  14:			;  по символу табуляции, пробелу, ":", ";" или символам конца строки
  15:			;Вход:		HL - адрес второго символа метки
  16:			;		A  - первый символ метки
  17:			;Выход: HL - адрес первого символа после метки
  18:			;
  19:			; процедура ScanLabel была полностью изменена в v0.2X
  20:	597E  0601    	ScanLabel	ld     b,1
  21:	5980  1802    			jr     ScanLabel2
  22:	5982  0600    	ScanLabel1	ld     b,0
  23:			
  24:	5984  11B069  	ScanLabel2	ld     de,WordBuf
  25:	5987  0EFC    			ld     c,#FC
  26:	5989  FE2E    			cp     "."
  27:	598B  2813    			jr     z,SL11
  28:	598D  FE40    			cp     "@"
  29:	598F  2027    			jr     nz,SL9
  30:	5991  7E      			ld     a, (hl)
  31:	5992  23      			inc    hl
  32:	5993  FE5F    			cp     "_"
  33:	5995  2805    			jr     z,SL7
  34:	5997  CD4A60  			call   Letter
  35:	599A  3025    			jr     nc,SL10
  36:	599C  CBFF    	SL7		set    7, a
  37:	599E  1826    			jr     SL5
  38:	59A0  E5      	SL11		push   hl
  39:	59A1  21AF6A  			ld     hl,SomeBuf ; новый буфер добавленный в v0.2X
  40:	59A4  7E      	SL8		ld     a, (hl)
  41:	59A5  B7      			or     a
  42:	59A6  2806    			jr     z,SL6
  43:	59A8  12      			ld     (de), a
  44:	59A9  13      			inc    de
  45:	59AA  23      			inc    hl
  46:	59AB  0D      			dec    c
  47:	59AC  18F6    			jr     SL8
  48:	59AE  3E2E    	SL6		ld     a,"."
  49:	59B0  12      			ld     (de), a
  50:	59B1  13      			inc    de
  51:	59B2  0D      			dec    c
  52:	59B3  E1      			pop    hl
  53:	59B4  7E      			ld     a, (hl)
  54:	59B5  23      			inc    hl
  55:	59B6  0602    			ld     b,2
  56:	59B8  FE5F    	SL9		cp     "_"
  57:	59BA  280A    			jr     z,SL5
  58:	59BC  CD4A60  			call   Letter
  59:	59BF  3805    			jr     c,SL5
  60:	59C1  0602    	SL10		ld     b,2
  61:	59C3  C37360  			jp     SkipStrC
  62:	59C6  0D      	SL5		dec    c
  63:	59C7  0C      			inc    c
  64:	59C8  2803    			jr     z,SL4
  65:	59CA  0D      			dec    c
  66:	59CB  12      			ld     (de), a
  67:	59CC  13      			inc    de
  68:	59CD  7E      	SL4		ld     a, (hl)
  69:	59CE  23      			inc    hl
  70:	59CF  FE5F    			cp     "_"
  71:	59D1  28F3    			jr     z,SL5
  72:	59D3  CD4A60  			call   Letter
  73:	59D6  38EE    			jr     c,SL5
  74:	59D8  CD5860  			call   Numeric
  75:	59DB  38E9    			jr     c,SL5
  76:	59DD  FE2E    			cp     "."
  77:	59DF  2008    			jr     nz,SL3
