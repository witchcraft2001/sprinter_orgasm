  86:	59EE  2811    			jr     z,SL1
  87:	59F0  E5      			push   hl
  88:	59F1  21B069  			ld     hl,WordBuf
  89:	59F4  11AF6A  			ld     de,SomeBuf ; новый буфер добавленный в v0.2X
  90:	59F7  D5      			push   de
  91:	59F8  01FF00  			ld     bc,255
  92:	59FB  EDB0    			ldir
  93:	59FD  E1      			pop    hl
