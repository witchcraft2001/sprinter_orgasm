**** d_oprnd.asm ****
   1:			;-----------------------------------------------------------------------------
   2:			;--		     Определение операндов мнемоник			    --
   3:			;-----------------------------------------------------------------------------
   4:			;Код операнда помещается в переменные Operand1 и Operand2
   5:			;и имеет следующие значения:
   6:			;#00 - нет операнда   #10 - DE		  #20 - (HL)
   7:			;#01 - A	      #11 - HL		  #21 - (IX)
   8:			;#02 - B	      #12 - SP		  #22 - (IX+n)
   9:			;#03 - C	      #13 - PO		  #23 - (IY)
  10:			;#04 - D	      #14 - NZ		  #24 - (IY+n)
  11:			;#05 - E	      #15 - PE		  #25 - (SP)
  12:			;#06 - H	      #16 - NC
  13:			;#07 - L	      #17 - IX
  14:			;#08 - I	      #18 - HX или XH
  15:			;#09 - R	      #19 - LX или XL
  16:			;#0A - M	      #1A - IY
  17:			;#0B - P	      #1B - HY или YH
  18:			;#0C - Z	      #1C - LY или YL
  19:			;#0D - AF	      #1D - (C)
  20:			;#0E - AF"	      #1E - (BC)	  #FE - (выражение)
  21:			;#0F - BC	      #1F - (DE)	  #FF - выражение
  22:			;
  23:			;Вход:		A  - первый символ операнда
  24:			;		HL - адрес следующего символа операнда
  25:			;Выход: A  - код символа, заканчивающий команду (";",":",#0D или ",")
  26:			;		HL - адрес следующего символа
  27:			; Operand1 - код первого операнда
  28:			; Operand2 - код второго операнда
  29:			;
  30:	56EC  FE20    	OperDetect	cp " "
  31:	56EE  CC6860  			call z,SkipSpace
  32:	56F1  FE09    			cp #09
  33:	56F3  CC6860  			call z,SkipSpace
  34:	56F6  FE0D    			cp #0d
  35:	56F8  C8      			ret z
  36:	56F9  FE3A    			cp ":"
  37:	56FB  C8      			ret z
  38:	56FC  FE3B    			cp ";"
  39:	56FE  C8      			ret z
  40:	56FF  CD5157  			call OD100	;определение первого операнда
  41:	5702  78      			ld a,b
  42:	5703  328B69  			ld (Operand1),a
  43:	5706  7E      			ld a,(hl)	;следующий за операндом символ
  44:	5707  23      			inc hl
  45:	5708  FE20    			cp " "
  46:	570A  CC6860  			call z,SkipSpace
  47:	570D  FE09    			cp #09
  48:	570F  CC6860  			call z,SkipSpace
  49:	5712  FE2C    			cp ","
  50:	5714  280E    			jr z,OD101	;ищем второй операнд
  51:	5716  FE0D    			cp #0d
  52:	5718  C8      			ret z
  53:	5719  FE3A    			cp ":"
  54:	571B  C8      			ret z
  55:	571C  FE3B    			cp ";"
  56:	571E  C8      			ret z
  57:	571F  0601    	OD10		ld b,SyntaxEr	;"Синтаксическая ошибка"
  58:	5721  C37360  			jp SkipStrC	;выход в головную программу
  59:			
  60:	5724  7E      	OD101		ld a,(hl)
  61:	5725  23      			inc hl
  62:	5726  FE20    			cp " "
  63:	5728  CC6860  			call z,SkipSpace
  64:	572B  FE09    			cp #09
  65:	572D  CC6860  			call z,SkipSpace
  66:	5730  CD5157  			call OD100
  67:	5733  78      			ld a,b
  68:	5734  328C69  			ld (Operand2),a
  69:	5737  7E      			ld a,(hl)	;следующий за операндом символ
  70:	5738  23      			inc hl
  71:	5739  FE20    			cp " "
  72:	573B  CC6860  			call z,SkipSpace
  73:	573E  FE09    			cp #09
  74:	5740  CC6860  			call z,SkipSpace
  75:	5743  FE0D    			cp #0d
  76:	5745  C8      			ret z
  77:	5746  FE3A    			cp ":"
  78:	5748  C8      			ret z
  79:	5749  FE3B    			cp ";"
  80:	574B  C8      			ret z
  81:	574C  0601    			ld b,SyntaxEr	;ошибка
  82:	574E  C37360  			jp SkipStrC
  83:			;
  84:			;Вход:		A  - первый символ операнда
  85:			;		HL - адрес следующего символа
  86:			;Выход: HL - адрес символа, идущего после операнда
  87:			;		B  - код определенного операнда
  88:			;
  89:	5751  5F      	OD100		ld e,a
