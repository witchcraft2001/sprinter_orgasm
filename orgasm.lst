  37:	6064  D0      			ret nc
  38:	6065  E6DF    			and #df
  39:	6067  C9      			ret
  40:			;
  41:			;-- Пропуск табуляции и пробелов --
  42:			;Вход:		HL - адрес следующего за пробелом символа
  43:			;Выход: A  - первый символ отличный от пробела
  44:			;		HL - адрес следующего символа
  45:			;		флаг С установлен
  46:			;
