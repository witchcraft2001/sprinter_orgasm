  91:	5755  381A    			jr c,OD1	;да - "C"
  92:			
  93:	5757  FE28    			cp "("		;операнд в скобках
  94:	5759  205C    			jr nz,ODVar
  95:	575B  7E      			ld a,(hl)
  96:	575C  23      			inc hl
  97:	575D  FE20    			cp " "		;пробел
  98:	575F  CC6860  			call z,SkipSpace
  99:	5762  FE09    			cp #09		;табуляция
 100:	5764  CC6860  			call z,SkipSpace
 101:	5767  2B      			dec hl
 102:	5768  CD4A60  			call Letter	;символ - буква?
 103:	576B  7B      			ld a,e
 104:	576C  3049    			jr nc,ODVar
 105:	576E  C3C658  			jp ODSkob	;да - "C"
 106:			
 107:	5771  7E      	OD1		ld a,(hl)	;смотрим следующий символ
 108:	5772  FE20    			cp " "		;операнд состоит из одного символа?
 109:	5774  CAEC57  			jp z,ODOne
 110:	5777  FE09    			cp #09
 111:	5779  CAEC57  			jp z,ODOne
 112:	577C  FE2C    			cp ","
 113:	577E  CAEC57  			jp z,ODOne
 114:	5781  FE0D    			cp #0d
 115:	5783  CAEC57  			jp z,ODOne
 116:	5786  FE3A    			cp ":"
 117:	5788  CAEC57  			jp z,ODOne
 118:	578B  FE3B    			cp ";"
 119:	578D  CAEC57  			jp z,ODOne
 120:			
 121:	5790  CD4A60  			call Letter	;символ - буква?
 122:	5793  3022    			jr nc,ODVar
 123:			
 124:	5795  47      			ld b,a
 125:	5796  23      			inc hl		;к 3-му символу операнда
 126:	5797  7E      			ld a,(hl)
 127:	5798  FE20    			cp " "		;операнд состоит из двух символов?
 128:	579A  CA1758  			jp z,ODTwo
 129:	579D  FE09    			cp #09
 130:	579F  CA1758  			jp z,ODTwo
 131:	57A2  FE2C    			cp ","
