   4:			;-- Проверка символа. Буква латинского алфавита или нет? --
   5:			;Вход:		A  - код символа
   6:			;Выход:"C" - буква
   7:			;      "NC"- другой символ
   8:			;
   9:	604A  FE41    	Letter		cp "A"
  10:	604C  3F      			ccf
  11:	604D  D0      			ret nc
  12:	604E  FE7B    			cp "{"
  13:	6050  D0      			ret nc
  14:	6051  FE5B    			cp "["
  15:	6053  D8      			ret c
  16:	6054  FE61    			cp "a"
  17:	6056  3F      			ccf
  18:	6057  C9      			ret
  19:			;
  20:			;-- Проверка символа. Цифра или нет? --
  21:			;Вход:		A  - код символа
  22:			;Выход:"C" - цифра
  23:			;      "NC"- другой символ
  24:			;
