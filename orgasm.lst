  96:	5A01  F1      	SL1		pop    af
  97:	5A02  C9      			ret
  98:			;
  99:			;-- Занесение метки в таблицу меток --
 100:			;
 101:			;Метка должна находиться в буфере WordBuf и заканчиваться #00
 102:			;При занесении метки возможно возникновение двух ошибок
 103:			;
 104:	5A03  E5      	NewLabel	push hl		;адрес в строке
 105:	5A04  F5      			push af		;текущий символ
 106:	5A05  CD5F60  			call CapsLetter
 107:	5A08  FE45    			cp "E"
 108:	5A0A  204F    			jr nz,NL5
 109:	5A0C  7E      			ld a,(hl)	;следующий символ
 110:	5A0D  23      			inc hl
 111:	5A0E  CD5F60  			call CapsLetter
 112:	5A11  FE51    			cp "Q"
 113:	5A13  2046    			jr nz,NL5
 114:	5A15  7E      			ld a,(hl)	;следующий символ
 115:	5A16  23      			inc hl
 116:	5A17  CD5F60  			call CapsLetter
 117:	5A1A  FE55    			cp "U"
 118:	5A1C  203D    			jr nz,NL5
 119:	5A1E  7E      			ld a,(hl)	;следующий символ
 120:	5A1F  23      			inc hl
 121:	5A20  FE09    			cp #09		;табуляция
 122:	5A22  2804    			jr z,$+6
 123:	5A24  FE20    			cp " "		;пробел
 124:	5A26  2033    			jr nz,NL5
 125:					
 126:	5A28  E5      			push hl
