  51:	606C  28FA    			jr z,SkipSpace
  52:	606E  FE20    			cp #20
  53:	6070  28F6    			jr z,SkipSpace
  54:	6072  C9      			ret
  55:			;
  56:			;-- Пропуск оставшейся части строки при возникновени ошибки --
  57:			;Вход:		A  - очередной символ строки
  58:			;		HL - адрес следующего символа строки
  59:			;		B  - номер ошибки
  60:			;Выход: HL - адрес начала новой строки
  61:			;
